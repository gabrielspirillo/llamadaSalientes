# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# DB
DATABASE_URL=
DIRECT_URL=

# Auth (Clerk)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Retell
RETELL_API_KEY=
RETELL_WEBHOOK_SIGNING_KEY=
# Agente inbound por defecto (fallback si el tenant no configuró el suyo)
RETELL_DEFAULT_AGENT_ID=
# Agente outbound (campañas y callbacks reactivos). Lo crea el script
# scripts/setup-outbound-agent.ts y lo guarda en agent_configs(role='outbound').
RETELL_OUTBOUND_DEFAULT_AGENT_ID=

# GoHighLevel
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=
GHL_WEBHOOK_PUBLIC_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# Retell SIP gateway para inbound (Twilio → Retell agent vía <Sip>).
# El dominio depende de la región del agente. Default público de Retell:
RETELL_SIP_DOMAIN=5t4n6j0wnrl.sip.livekit.cloud

# Queue (Redis + BullMQ). Self-hosted en Dokploy.
# Formato: redis://[:password]@host:port[/db]
# En Dokploy, el host suele ser el nombre del service: redis://redis:6379
REDIS_URL=redis://redis:6379

# Worker concurrency (opcional). Default 2 por queue.
WORKER_CONCURRENCY_WA=2
WORKER_CONCURRENCY_CALL=2

# Storage R2 (grabaciones de Retell)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Storage S3-compatible (adjuntos del inbox de WhatsApp).
# Por default está pensado para MinIO self-hosted en Dokploy. Cambiar
# S3_ENDPOINT a https://<account>.r2.cloudflarestorage.com si se prefiere R2.
# - S3_ENDPOINT: URL interna del cluster MinIO. En Dokploy: http://minio:9000
# - S3_PUBLIC_BASE_URL: URL pública (Traefik) para construir links del inbox UI.
# - S3_BUCKET_WHATSAPP: nombre del bucket (debe existir; público para que el
#   inbox UI lo embeba directo. Si privado, usar mediaSignedUrl en el código).
# - S3_FORCE_PATH_STYLE: true para MinIO (default).
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_BASE_URL=https://s3.futuradigital.es
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_WHATSAPP=whatsapp-media
S3_FORCE_PATH_STYLE=true

# Crypto (32 bytes base64 — generar con: openssl rand -base64 32)
ENCRYPTION_KEY=

# Observabilidad
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# OpenAI (resúmenes de llamadas + Whisper para audios de WhatsApp)
OPENAI_API_KEY=
# Modelo de transcripción para WhatsApp (audio del paciente → texto). Default: whisper-1.
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Gemini (Vision para imágenes/PDFs del agente de WhatsApp + summaries de
# llamadas en lib/gemini/client.ts). Si no está seteado, el agente de WhatsApp
# devuelve placeholders en imágenes y PDFs y deja que el LLM principal decida
# handoff.
GEMINI_API_KEY=
# Modelo para describir imágenes/PDFs entrantes. Override si necesitás algo
# más potente (ej: gemini-pro-latest para PDFs largos). Default: gemini-flash-latest.
GEMINI_VISION_MODEL=gemini-flash-latest
# Modelo del agente conversacional WhatsApp (tool-calling).
# Default: gemini-flash-latest. Fallback automático a OpenAI ante errores.
GEMINI_AGENT_MODEL=gemini-flash-latest
OPENAI_AGENT_FALLBACK_MODEL=gpt-4o-mini

# Feature flag global del agente IA de WhatsApp.
# Por seguridad arranca apagado: los webhooks encolan el job pero el worker
# sale inmediatamente sin invocar al LLM. Setear =true para encender en
# producción (después de validar por tenant).
WHATSAPP_AGENT_ENABLED=false

# ── Demo público (landing Hostinger) ─────────────────────────────────────────
# Tenant que dispara las llamadas cuando alguien rellena el form de la landing.
# Tiene que tener: phone_numbers activo, ghl_integrations conectado, agent_configs(role='outbound')
# apuntando a agent_b7c4de5748c40e118d193db2f6 (correr scripts/setup-futura-demo-agent.ts).
FUTURA_DEMO_TENANT_ID=
# Origins permitidos para CORS del endpoint /api/public/demo-call. Coma-separados.
FUTURA_DEMO_ALLOWED_ORIGINS=https://cliniq.futuradigital.es,https://www.cliniq.futuradigital.es
# Retell agent_id que atiende las llamadas demo (Manuel — FUTURA Demo Outbound).
# Override aplicado SOLO en /api/public/demo-call; el dashboard outbound sigue
# usando agent_configs(role='outbound') del tenant.
FUTURA_DEMO_RETELL_AGENT_ID=agent_b7c4de5748c40e118d193db2f6
# Override GHL exclusivo para llamadas que vienen de la landing
# (metadata.source='landing_demo'). Cuando los 3 están seteados,
# register_patient / check_availability / book_appointment operan contra
# este location/PIT/calendar en lugar del GHL del tenant. Permite que la
# demo agende en un GHL dedicado de FUTURA sin tocar el GHL configurado
# para el tenant (que se sigue usando para inbound u otros flows del mismo
# tenant). Si falta alguno de los 3, el override no se activa y cae al GHL
# del tenant (comportamiento previo).
FUTURA_DEMO_GHL_PIT=
FUTURA_DEMO_GHL_LOCATION_ID=
FUTURA_DEMO_GHL_CALENDAR_ID=
