# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# DB
DATABASE_URL=
DIRECT_URL=

# Auth (Clerk)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Retell
RETELL_API_KEY=
RETELL_WEBHOOK_SIGNING_KEY=
# Agente inbound por defecto (fallback si el tenant no configuró el suyo)
RETELL_DEFAULT_AGENT_ID=
# Agente outbound (campañas y callbacks reactivos). Lo crea el script
# scripts/setup-outbound-agent.ts y lo guarda en agent_configs(role='outbound').
RETELL_OUTBOUND_DEFAULT_AGENT_ID=

# GoHighLevel
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=
GHL_WEBHOOK_PUBLIC_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# Retell SIP gateway para inbound (Twilio → Retell agent vía <Sip>).
# El dominio depende de la región del agente. Default público de Retell:
RETELL_SIP_DOMAIN=5t4n6j0wnrl.sip.livekit.cloud

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Storage R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Crypto (32 bytes base64 — generar con: openssl rand -base64 32)
ENCRYPTION_KEY=

# Observabilidad
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# OpenAI (resúmenes)
OPENAI_API_KEY=

# ── Demo público (landing Hostinger) ─────────────────────────────────────────
# Tenant que dispara las llamadas cuando alguien rellena el form de la landing.
# Tiene que tener: phone_numbers activo, ghl_integrations conectado, agent_configs(role='outbound')
# apuntando a agent_b7c4de5748c40e118d193db2f6 (correr scripts/setup-futura-demo-agent.ts).
FUTURA_DEMO_TENANT_ID=
# Origins permitidos para CORS del endpoint /api/public/demo-call. Coma-separados.
FUTURA_DEMO_ALLOWED_ORIGINS=https://cliniq.futuradigital.es,https://www.cliniq.futuradigital.es
