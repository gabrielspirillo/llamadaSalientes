# Source control
.git
.gitignore
.gitattributes

# Editor / OS
.vscode
.idea
.DS_Store
*.swp

# Deps and build artifacts (se reconstruyen dentro del contenedor)
**/node_modules
**/.next
**/dist
**/coverage
**/playwright-report
**/test-results

# Env files — NUNCA dentro de la imagen. Dokploy inyecta env runtime.
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# Local-only
.devcontainer
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Tests / docs (no rompen el build pero engordan el contexto)
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/__tests__
**/tests/e2e
README.md
**/*.md
# docs/ SI entra a la imagen: el visor /docs los lee en runtime
# (llegan al standalone via outputFileTracingIncludes en next.config.ts).
!docs/*.md

# CI
.github
